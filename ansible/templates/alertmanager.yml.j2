global:
  resolve_timeout: 5m

route:
  group_by: ['alertname']
  group_wait: 10s
  group_interval: 10s
  repeat_interval: 1h
  receiver: 'telegram-notifications'

receivers:
  - name: 'telegram-notifications'
    telegram_configs:
    - bot_token: '{{ telegram_bot_token }}'
      chat_id: {{ telegram_chat_id }}
      send_resolved: true
