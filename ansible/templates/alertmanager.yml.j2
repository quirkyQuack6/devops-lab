global:
  resolve_timeout: 5m
  http_config:
    proxy_url: 'http://192.168.122.1:10808'

route:
  group_by: ['alertname']
  group_wait: 10s
  group_interval: 10s
  repeat_interval: 1h
  receiver: 'telegram-notifications'

receivers:
  - name: 'telegram-notifications'
    telegram_configs:
    - bot_token: '{{ telegram_bot_token }}'
      chat_id: {{ telegram_chat_id }}
      send_resolved: true
      parse_mode: 'HTML'
      message: |
        {{ range .Alerts }}
        <b>[ALERT] {{ .Status | toUpper }}</b>
        <b>Инцидент:</b> {{ .Labels.alertname }}
        <b>Уровень:</b> <code>{{ .Labels.severity }}</code>
        <b>Описание:</b> {{ .Annotations.description }}
        <b>Время:</b> {{ .StartsAt.Format "15:04:05" }}
        {{ end }}
